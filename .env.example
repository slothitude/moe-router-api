# External API Configuration for Pi Agent Boss
# Copy this file to .env and fill in your actual API keys

# NVIDIA NIM API Key
# Get your key at: https://build.nvidia.com/
# Required for accessing NVIDIA's hosted Llama models (e.g., Llama 3.1 405B)
NVIDIA_API_KEY=nvapi-your-key-here

# OpenAI API Key (optional - for future expansion)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-key-here

# MiniMax API Key (optional - for future expansion)
# MINIMAX_API_KEY=your-key-here
